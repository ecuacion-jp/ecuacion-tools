<FindBugsFilter
  xmlns="https://github.com/spotbugs/filter/3.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

  <!--
    AbstractTask/AbstractTaskSftp declare connection/fromPath/destPath as @Nullable because the
    parameters are shared across all task types (e.g. local tasks never receive a connection,
    create-only tasks never receive a srcPath). For these concrete leaf task classes, the value
    is always non-null at runtime: HousekeepFilesBl only invokes doTask() after check() has
    verified the field is REQUIRED for this specific taskPtn, and connections are only omitted
    for local tasks that never extend AbstractTaskSftp. SpotBugs cannot see that business-rule
    guarantee and flags the unconditional dereference as a NonNull-contract violation.
  -->
  <Match>
    <Bug pattern="NP_PARAMETER_MUST_BE_NONNULL_BUT_MARKED_AS_NULLABLE" />
    <Class name="~jp\.ecuacion\.tool\.housekeepfiles\.bl\.task\.(AbstractTaskZip|CreateDir|CreateFile|Delete|SftpCopyFromServer|SftpCopyToServer|SftpCreateDir|SftpDeleteFromServer|SftpMoveFromServer|SftpMoveToServer)" />
  </Match>

</FindBugsFilter>
